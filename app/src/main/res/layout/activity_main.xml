<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:padding="32dp" android:background="#0f172a">
    <TextView android:text="VNT" android:textSize="48sp" android:textColor="#818cf8"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:letterSpacing="0.3" android:layout_marginBottom="8dp"/>
    <TextView android:text="AI CALLER" android:textSize="14sp" android:textColor="#4a6080"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"/>
    <Switch android:id="@+id/enableSwitch"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Enable AI Answering" android:textColor="#e8f0f8"
        android:layout_marginBottom="32dp"/>
    <TextView android:id="@+id/status"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#4a6080" android:textSize="13sp"
        android:gravity="center" android:lineSpacingExtra="6dp"/>
</LinearLayout>
